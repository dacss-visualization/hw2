mtcars_cyl=mtcars$cyl|>table()|>as.data.frame()
#new object DF
mtcars_cyl
# using the new DF
ggplot(mtcars_cyl, aes(x=factor(Var1), y=Freq, label=Freq)) +
geom_col() +
geom_text()  # this uses aes(label=Freq)
# using the new DF
ggplot(mtcars_cyl, aes(x=factor(Var1), y=Freq)) +
geom_col() +
geom_text(aes(label=Freq))  # notice
ggplot(mtcars_cyl, aes(x=factor(Var1), y=Freq, label=Freq)) +
geom_col() +
geom_text(vjust=-1)
plot1= ggplot(mtcars_cyl, aes(x=factor(Var1), y=Freq, label=Freq)) +
geom_bar(stat = 'identity') +
geom_text(vjust=-1)
ggplot(mtcars_cyl, aes(x=factor(Var1), y=Freq, label=Freq)) +
geom_bar(stat = 'identity') +
geom_text(vjust=-1)
plot1+  labs(title = 'some bars',subtitle = 'annotated bars', caption = 'caption here',x='cylinders')
#you aleady have aes(label=Freq)
plot1 + annotate("text", x = 2, y = 10,
label = "This is an annotation",
color = "red", fontface = "bold", size = 5)
plot1 + annotate("text", x = 2, y = 10,
label = "This is \n an annotation",
color = "red", fontface = "bold", size = 5)
plot2= ggplot(mtcars_cyl, aes(x=factor(Var1), y=Freq, label=Freq)) +
geom_bar(stat = 'identity') +
geom_text(hjust=2,size=10, color='white',fontface = "bold") + coord_flip()
plot2  + labs(x='cylinders', y='counts')
plot2  + labs(x='cylinders') + theme_void()
plot2  + labs(x='cylinders') + theme_classic()
plot2_a=plot2  + labs(x='cylinders', title = 'frequency of car cylinders') + theme_classic()
plot2_a
plot2_b=plot2_a + theme(axis.title.x = element_blank(),
axis.line.x = element_blank(),
axis.text.x = element_blank(),
axis.ticks.x = element_blank())
plot2_b
plot2_c=plot2_b + theme(plot.title = element_text(size=30,face='bold'),
axis.title.y = element_text(size=15,face='bold'),
axis.text.y = element_text(size=20,face='bold',angle=45) )
plot2_c
