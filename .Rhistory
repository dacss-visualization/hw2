gears <- mtcars$gear|>table()|>as.data.frame()
head(gears)
plot_gear <- ggplot(gears, aes(x=factor(Var1), y=Freq, label=Freq)) +
geom_bar(stat = 'identity', fill = "steelblue") +
geom_text(hjust=1,size=7, color='darkblue', fontface = "bold") +
coord_flip()
plot_gear  + labs(title = 'Count of Cars per GEAR', x='Gear', y = NULL, caption = "Source: mtcars data")
gears_carbs <- mtcars |>
count(cyl, carb, gear) |>
mutate(percent = n /sum(n) * 100)
head(gears_carbs)
plot_dist <- ggplot(gears_carbs, aes(x = factor(cyl), y = n)) +
geom_bar(stat= "identity", fill = "orange") +
geom_text(aes(label = paste0(round(percent,1), "%")),
vjust = 1.5, fontface = "bold") +
facet_grid(gear ~ carb, labeller = label_both) +
labs(
title = "Distribution of Cylinder Counts by Carburetors and Gears",
x = "Cylinders",
y = "Count",
caption = "Source: mtcars dataset"
) +
theme_minimal()
plot_dist
knitr::opts_chunk$set(fig.width=6, fig.height=4, fig.align="center")
##setting up library
library(flexdashboard)
library(ggplot2)
library(tidyverse)
##setting up library
library(flexdashboard)
library(ggplot2)
library(tidyverse)
#creating carb variable and frequency dataframe
carbs <- mtcars$carb|>table()|>as.data.frame()
##plotting carb frequency
plot_carb <- ggplot(carbs, aes(x=factor(Var1), y=Freq, label=Freq)) +
geom_bar(stat = 'identity', fill = "gold") +
geom_text(hjust=1,size=4, color='darkblue', fontface = "bold") +
labs(title = 'Count of Cars per CARB', x='CARB', y = NULL, caption = "Source: mtcars data")
plot_carb
#creating gear variable and frequency dataframe
gears <- mtcars$gear|>table()|>as.data.frame()
##plotting gear frequency
plot_gear <- ggplot(gears, aes(x=factor(Var1), y=Freq, label=Freq)) +
geom_bar(stat = 'identity', fill = "steelblue") +
geom_text(hjust=1,size=7, color='darkblue', fontface = "bold") +
coord_flip()
plot_gear  + labs(title = 'Count of Cars per GEAR', x='Gear', y = NULL, caption = "Source: mtcars data")
#counts for cylindar, carbs and gears
#finding percentages of counts
gears_carbs <- mtcars |>
count(cyl, carb, gear) |>
mutate(percent = n /sum(n) * 100)
##plotting
plot_dist <- ggplot(gears_carbs, aes(x = factor(cyl), y = n)) +
geom_bar(stat= "identity", fill = "orange") +
geom_text(aes(label = paste0(round(percent,1), "%")),
vjust = 1.5, fontface = "bold") +
facet_grid(gear ~ carb, labeller = label_both) +
labs(
title = "Distribution of Cylinder Counts by Carburetors and Gears",
x = "Cylinders",
y = "Count",
caption = "Source: mtcars dataset"
) +
theme_minimal()
plot_dist
